rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.agentId;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
    }
    
    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
    }

    // Field Visit Rules
    match /field_visits/{visitId} {
      allow read: if isAuthenticated() && resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Lead Rules
    match /leads/{leadId} {
      allow read: if isAuthenticated() && resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Property Rules
    match /properties/{propertyId} {
      allow read: if isAuthenticated() && resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Tasks Rules
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Gamified Tasks Rules
    match /gamified_tasks/{taskId} {
      allow read: if isAuthenticated() && resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Map Pins Rules
    match /map_pins/{pinId} {
      allow read: if isAuthenticated() && resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Message Templates Rules
    match /message_templates/{templateId} {
      allow read: if isAuthenticated() && resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Broker Accounts Rules
    match /broker_accounts/{accountId} {
      allow read: if isAuthenticated() && resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // External Listings Rules
    match /external_listings/{listingId} {
      allow read: if isAuthenticated() && resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Rescue Sessions Rules
    match /rescue_sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }
  }
}
