{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile and subscription information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "subscriptionType": { "type": "string", "enum": ["none", "1-month", "3-month", "6-month", "12-month"], "description": "Current subscription plan" },
        "subscriptionEndDate": { "type": "string", "format": "date-time", "description": "When the subscription expires" },
        "role": { "type": "string", "enum": ["agent", "admin"], "description": "User role" }
      },
      "required": ["uid", "email"]
    },
    "field_visits": {
      "title": "Field Visit",
      "description": "Records of visits to buildings.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string", "description": "UID of the agent" },
        "address": { "type": "string", "description": "Building address" },
        "status": { "type": "string", "enum": ["Görüşüldü", "Potansiyel", "Ret", "Boş"] },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "address", "status"]
    },
    "leads": {
      "title": "Lead",
      "description": "Potential clients or portfolios.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string", "description": "UID of the agent" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["Aday", "Sıcak", "Yetki Alındı", "Pasif"] },
        "notes": { "type": "string" },
        "lastContact": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "name", "phone"]
    },
    "properties": {
      "title": "Property",
      "description": "Real estate listings managed by the agent.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string", "description": "UID of the agent" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Daire", "Villa", "Arsa", "Ticari", "Fabrika", "Fabrika Arsası"] },
        "category": { "type": "string", "enum": ["Satılık", "Kiralık"] },
        "price": { "type": "number" },
        "commissionRate": { "type": "number" },
        "status": { "type": "string", "enum": ["Yeni", "Hazırlanıyor", "Yayında", "İlgi Var", "Pazarlık", "Satıldı", "Pasif"] },
        "address": {
          "type": "object",
          "properties": {
            "city": { "type": "string" },
            "district": { "type": "string" },
            "neighborhood": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "details": {
          "type": "object",
          "properties": {
            "brutM2": { "type": "number" },
            "netM2": { "type": "number" },
            "rooms": { "type": "string" },
            "age": { "type": "number" },
            "floor": { "type": "number" }
          }
        },
        "owner": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "trustScore": { "type": "number" }
          }
        },
        "healthScore": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "title", "price", "status"]
    },
    "map_pins": {
      "title": "Map Pin",
      "description": "Pins added to the map by the agent.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string", "description": "UID of the agent" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "lat", "lng", "type", "title"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "users", "description": "User profile document" },
    "/field_visits/{visitId}": { "schema": "field_visits", "description": "Field visit records" },
    "/leads/{leadId}": { "schema": "leads", "description": "Lead records" },
    "/properties/{propertyId}": { "schema": "properties", "description": "Real estate property records" },
    "/map_pins/{pinId}": { "schema": "map_pins", "description": "Map pins records" }
  }
}
